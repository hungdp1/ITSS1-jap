# ===== Tomoio (full Supabase, single Next.js app, deploys to Vercel) =====
# Copy to .env.local and fill in. These same vars must be set in Vercel.

# Supabase Postgres via the Supavisor transaction pooler (port 6543).
# Supabase Dashboard > Project Settings > Database > Connection string > "Transaction pooler".
# URL-encode special characters in the password.
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:6543/postgres

# Supabase project URL + publishable (anon) key — Dashboard > Project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_STORAGE_BUCKET=uploads

# Optional: a secret/service key for clean server-side Storage writes.
# If omitted, the anon key + the `uploads` bucket policy is used (see database/supabase_setup.sql).
# SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Custom JWT auth (kept from the original backend). Use a long random secret.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
